# StellarYield Keeper Bot — Environment Configuration
# Copy to .env and fill in your secrets. NEVER commit real values.

# ── Stellar Network ──────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
# Horizon RPC endpoint
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Soroban RPC endpoint
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Keeper Wallet ───────────────────────────────────────────────────────────
# Secret key for the keeper bot account. In production, use KMS integration.
KEEPER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Base fee in stroops (default 100)
BASE_FEE=100

# ── Contract Addresses ───────────────────────────────────────────────────────
VAULT_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STABLECOIN_MANAGER_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Keeper Configuration ─────────────────────────────────────────────────────
# Interval (ms) between each vault scan cycle
SCAN_INTERVAL_MS=30000
# Minimum CR in bps below which a CDP is flagged (should match contract MCR)
MCR_BPS=11000
# Max concurrent liquidation jobs being processed at once
LIQUIDATION_CONCURRENCY=3
# Max concurrent compound jobs
COMPOUND_CONCURRENCY=5
# Job retry attempts before it is moved to failed queue
JOB_MAX_ATTEMPTS=5

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
